# =====================================================================
# Procurador de Câmara — Configuração
# =====================================================================

# ── Censys (descoberta global de câmaras IP) ────────────────────────
# Personal Access Token da Censys Platform API v3 (recomendado):
#   1. Vai a https://accounts.censys.io/settings/personal-access-tokens
#   2. Cria um token com nome "IPCAM"
#   3. Copia o token
#
# NOTA: Contas gratuitas SÓ permitem host lookup (não search).
#       Para search completo, precisas de plano Starter (pago).
CENSYS_PERSONAL_ACCESS_TOKEN="censys_yeaY2Mj9kkhVpEUVcNtFhMPPKqy5bK7Mv"

# Alternativa (mesmo que CENSYS_PERSONAL_ACCESS_TOKEN):
# CENSYS_API_KEY="censys_yeaY2Mj9kkhVpEUVcNtFhMPPKqy5bK7Mv"

# Alternativa clássica (API ID + Secret, obsoleto):
# CENSYS_API_ID="sua-api-id"
# CENSYS_SECRET="seu-secret"

# ── Shodan (fonte alternativa de descoberta) ───────────────────────
# Usa: python -m procurador --shodan
#   1. Vai a https://account.shodan.io
#   2. Copia a API key
#
# NOTA: Contas gratuitas sem créditos NÃO permitem search.
#       Search requer membership paga.
SHODAN_API_KEY="vPJOSxzsTuPz4WTE4pJjT5KkgilXoOYs"

# ── ipinfo.io (localização geográfica) ──────────────────────────────
# Opcional. Token gratuito em https://ipinfo.io
IPINFO_TOKEN=""

# ── Alertas ─────────────────────────────────────────────────────────
# Modo daemon: python -m procurador --daemon
# Descomenta para ativar notificações:
# TELEGRAM_BOT_TOKEN="seu_bot_token"
# TELEGRAM_CHAT_ID="seu_chat_id"
# DISCORD_WEBHOOK="sua_webhook_url"

# ── Scan ────────────────────────────────────────────────────────────
# CENSYS_QUERY="services.service_name: RTSP"
# CENSYS_COUNTRY="PT"             # Filtrar por país (opcional)
# CENSYS_MAX_PAGES=5
# BRUTE_ENABLED=true
# STREAM_CAPTURE=false            # Caro em larga escala
# ONVIF_ENABLED=true
# GEOIP_ENABLED=true
# LOCAL_SUBNET="192.168.1.0/24"
# STEALTH=false
# RTSP_PROBE_TIMEOUT=3.0
