# =====================================================================
# Procurador de Câmara — Configuração
# =====================================================================

# ── Censys (descoberta global de câmaras IP) ────────────────────────
# Usa Personal Access Token da Censys Platform API v2:
#   1. Vai a https://search.censys.io/account/api
#   2. Cria um Personal Access Token
#   3. Copia o token para aqui
CENSYS_API_KEY="Qtdg3uaj_m2DUPXzwr5jQkFr64brGDyuR"

# Alternativa clássica (API ID + Secret, v1 obsoleto):
# CENSYS_API_ID="sua-api-id"
# CENSYS_SECRET="seu-secret"

# ── ipinfo.io (localização geográfica) ──────────────────────────────
# Opcional. Obtém localização + ISP de IPs escaneados.
IPINFO_TOKEN=""

# ── Scan ────────────────────────────────────────────────────────────
# CENSYS_QUERY="services.service_name: RTSP"
# CENSYS_COUNTRY="PT"             # Filtrar por país (opcional)
# CENSYS_MAX_PAGES=5
# BRUTE_ENABLED=true
# STREAM_CAPTURE=false            # Caro em larga escala
# ONVIF_ENABLED=true
# GEOIP_ENABLED=true
# LOCAL_SUBNET="192.168.1.0/24"
# STEALTH=false
# RTSP_PROBE_TIMEOUT=3.0
